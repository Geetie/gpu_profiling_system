{
  "_provider": "anthropic",
  "_name": "Anthropic Claude",
  "_description": "Anthropic官方Claude API配置",
  "_models": {
    "default": "claude-3-sonnet-20240229",
    "reasoning": "claude-3-opus-20240229",
    "haiku": "claude-3-haiku-20240229",
    "sonnet": "claude-3-sonnet-20240229",
    "opus": "claude-3-opus-20240229"
  },
  "_endpoints": {
    "base": "https://api.anthropic.com",
    "chat": "https://api.anthropic.com/v1/messages"
  },
  "_auth": {
    "type": "api_key",
    "header": "x-api-key",
    "format": "{api_key}",
    "env_var": "ANTHROPIC_API_KEY"
  },
  "_headers": {
    "Content-Type": "application/json",
    "x-api-key": "{api_key}",
    "anthropic-version": "2023-06-01"
  },
  "_request_format": {
    "model": "{model}",
    "messages": "{messages}",
    "max_tokens": "{max_tokens}",
    "stream": false
  },
  "_supported_features": [
    "chat_completion",
    "streaming",
    "tool_use",
    "thinking"
  ],
  "_rate_limits": {
    "requests_per_minute": 50,
    "tokens_per_minute": 40000
  },
  "_cost": {
    "claude-3-opus-20240229": {"input": 0.015, "output": 0.075},
    "claude-3-sonnet-20240229": {"input": 0.003, "output": 0.015},
    "claude-3-haiku-20240229": {"input": 0.00025, "output": 0.00125}
  }
}