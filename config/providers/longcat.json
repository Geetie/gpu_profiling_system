{
  "_provider": "longcat",
  "_name": "美团 LongCat API",
  "_description": "美团 LongCat Flash 系列模型配置",
  "_models": {
    "default": "LongCat-Flash-Chat",
    "reasoning": "LongCat-Flash-Chat",
    "haiku": "LongCat-Flash-Chat",
    "sonnet": "LongCat-Flash-Chat",
    "opus": "LongCat-Flash-Chat"
  },
  "_endpoints": {
    "base": "https://api.longcat.chat/openai",
    "chat": "https://api.longcat.chat/openai/v1/chat/completions"
  },
  "_auth": {
    "type": "api_key",
    "header": "Authorization",
    "format": "Bearer {api_key}",
    "env_var": "LONGCAT_API_KEY"
  },
  "_headers": {
    "Content-Type": "application/json",
    "Authorization": "Bearer {api_key}"
  },
  "_request_format": {
    "model": "{model}",
    "messages": "{messages}",
    "max_tokens": "{max_tokens}",
    "stream": false
  },
  "_supported_features": [
    "chat_completion",
    "streaming",
    "function_calling"
  ],
  "_rate_limits": {
    "requests_per_minute": 1000,
    "tokens_per_minute": 1000000
  },
  "_cost": {
    "LongCat-Flash-Omni-2603": {"input": 0.001, "output": 0.001},
    "LongCat-Flash-Thinking-2601": {"input": 0.002, "output": 0.002}
  }
}